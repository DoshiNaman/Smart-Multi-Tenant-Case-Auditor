{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/api",
      "framework": "nestjs",
      "config": {
        "outputFileTracingIncludes": {
          "**/*": ["./node_modules/@nestjs/**"]
        }
      }
    }
  }
}